<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_landing"
    android:padding="24dp"
    tools:context=".screens.UpgradesActivity">

    <ScrollView
        android:id="@+id/scroll_upgrades"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/content_upgrades"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_upgrades_logo"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:contentDescription="@string/app_name"
                app:srcCompat="@mipmap/ic_launcher" />

            <TextView
                android:id="@+id/tv_upgrades_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Upgrades"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_upgrades_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Upgrade your abilities to progress faster"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp" />

            <!-- Row 1: Mine level -->
            <LinearLayout
                android:id="@+id/card_upgrade_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/iv_upgrade_1_image"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="Mine upgrade image"
                    android:scaleType="fitCenter"
                    tools:src="@android:drawable/ic_menu_manage" />

                <TextView
                    android:id="@+id/tv_upgrade_1_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Mine level"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Upgrade cost"
                    app:hintTextColor="#CCFFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_upgrade_1_cost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textIsSelectable="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/pb_upgrade_1"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#33FFFFFF"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="40"
                    android:progressTint="#FFB9B2FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade_1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Upgrade mine level"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="#FFB9B2FF"
                    app:strokeColor="#FFB9B2FF"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <!-- Row 2: Radius -->
            <LinearLayout
                android:id="@+id/card_upgrade_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/iv_upgrade_2_image"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="Radius upgrade image"
                    android:scaleType="fitCenter"
                    tools:src="@android:drawable/ic_menu_mylocation" />

                <TextView
                    android:id="@+id/tv_upgrade_2_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Mine detection radius"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Upgrade cost"
                    app:hintTextColor="#CCFFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_upgrade_2_cost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textIsSelectable="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/pb_upgrade_2"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#33FFFFFF"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="25"
                    android:progressTint="#FFB9B2FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade_2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Upgrade radius"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="#FFB9B2FF"
                    app:strokeColor="#FFB9B2FF"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <!-- Row 3: Efficiency -->
            <LinearLayout
                android:id="@+id/card_upgrade_row_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/iv_upgrade_3_image"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="Efficiency upgrade image"
                    android:scaleType="fitCenter"
                    tools:src="@android:drawable/ic_menu_recent_history" />

                <TextView
                    android:id="@+id/tv_upgrade_3_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Efficiency"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Upgrade cost"
                    app:hintTextColor="#CCFFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_upgrade_3_cost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:text="—"
                        android:textColor="@color/white"
                        android:textIsSelectable="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/pb_upgrade_3"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#33FFFFFF"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="60"
                    android:progressTint="#FFB9B2FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade_3"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Upgrade efficiency"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_recent_history"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="#FFB9B2FF"
                    app:strokeColor="#FFB9B2FF"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <!-- Row 4: Backpack size -->
            <LinearLayout
                android:id="@+id/card_upgrade_row_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_auth_card"
                android:orientation="vertical"
                android:padding="18dp">

                <ImageView
                    android:id="@+id/iv_upgrade_4_image"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:contentDescription="Backpack size upgrade image"
                    android:scaleType="fitCenter"
                    tools:src="@android:drawable/ic_menu_upload" />

                <TextView
                    android:id="@+id/tv_upgrade_4_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Backpack size"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Upgrade cost"
                    app:hintTextColor="#CCFFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_upgrade_4_cost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textIsSelectable="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <ProgressBar
                    android:id="@+id/pb_upgrade_4"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#33FFFFFF"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="10"
                    android:progressTint="#FFB9B2FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade_4"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Upgrade backpack size"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="#00000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_input_get"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconTint="#FFB9B2FF"
                    app:strokeColor="#FFB9B2FF"
                    app:strokeWidth="2dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
