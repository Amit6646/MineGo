<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_auth_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardBackgroundColor="#33FFFFFF"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeColor="#55FFFFFF"
        app:strokeWidth="1dp">

        <TextView
            android:id="@+id/tv_user_initials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="A"
            android:textColor="#FFB9B2FF"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="A" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_item_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Amit6646" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="#99FFFFFF" />

            <TextView
                android:id="@+id/tv_item_user_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                tools:text="user@example.com" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center|end"
        android:orientation="vertical">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_user_role"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Admin"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:visibility="gone"
            app:chipBackgroundColor="#44B9B2FF"
            app:chipStrokeColor="#FFB9B2FF"
            app:chipStrokeWidth="1dp"
            tools:visibility="visible" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="6dp"
            android:contentDescription="@null"
            android:src="@android:drawable/ic_menu_more"
            app:tint="#FFB9B2FF" />
    </LinearLayout>

</LinearLayout>
