<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_landing"
    android:padding="24dp"
    tools:context=".screens.Mini_Game_Activity">

    <LinearLayout
        android:id="@+id/content_minigame"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <ImageView
            android:id="@+id/iv_minigame_logo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:contentDescription="@string/app_name"
            app:srcCompat="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/tv_minigame_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Mining"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_minigame_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Tap the mine to break it and earn rewards"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/card_minigame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_auth_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_minigame_hp_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Mine health"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_minigame_temp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="HP: 100"
                android:textColor="#FFB9B2FF"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="HP: 45 / 100" />

            <ProgressBar
                android:id="@+id/pb_minigame_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#33FFFFFF"
                android:indeterminate="false"
                android:max="100"
                android:progress="100"
                android:progressTint="#FFB9B2FF" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:minHeight="260dp">

                <ImageButton
                    android:id="@+id/btn_minigame_temp"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Tap to mine"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mine1" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_minigame_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Every time you click on the mine it will process X HP"
                android:textColor="#99FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
